# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Notion API - Múltiples bases de datos
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_tasks_database_id_here  # Base de datos de tareas (principal)
NOTION_NOTES_DB_ID=your_notion_notes_database_id_here  # Base de datos de notas (opcional)
NOTION_PROJECTS_DB_ID=your_notion_projects_database_id_here  # Base de datos de proyectos (opcional)
NOTION_HABITS_DB_ID=your_notion_habits_database_id_here  # Base de datos de hábitos (opcional)

# Google Calendar API
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=token.json
GOOGLE_CALENDAR_ID=primary

# Clockify API (Time Tracking)
CLOCKIFY_API_KEY=your_clockify_api_key_here
CLOCKIFY_WORKSPACE_ID=your_clockify_workspace_id_here

# Focusmate API
FOCUSMATE_API_KEY=your_focusmate_api_key_here

# Beeminder API
BEEMINDER_AUTH_TOKEN=your_beeminder_auth_token_here
BEEMINDER_USERNAME=your_beeminder_username_here

# RescueTime API
RESCUETIME_API_KEY=your_rescuetime_api_key_here

# ElevenLabs API (Text-to-Speech de alta calidad)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Rachel (default), ver otras en https://elevenlabs.io/voices
ELEVENLABS_MODEL_ID=eleven_multilingual_v2  # Modelo multilingüe recomendado para español

# Audio Configuration
AUDIO_TEMP_DIR=./temp_audio
MAX_AUDIO_DURATION=300  # segundos

# Context Caching - Documentos
DOCUMENTS_DIR=./documents  # Directorio con documentos para cachear
DOCUMENT_PATHS=  # Rutas específicas separadas por coma (opcional)
CACHE_TTL_MINUTES=60  # Tiempo de vida del cache en minutos

